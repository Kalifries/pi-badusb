REM === BadUSB Startup Processes  ===
REM Opens terminal on target and opens fastfetch, NMCLI,
REM tcpdump, and tshark and then leaves a command prompt ready.

DELAY 500
CTRL ALT t
DELAY 3000
STRING ssh -i ~/.ssh/pizero_key transient@192.168.1.132
ENTER
DELAY 2000
STRING realshookones
ENTER
DELAY 5000
STRING fastfetch
ENTER
DELAY 3000
STRING nmcli device wifi list
ENTER
DELAY 3000
STRING sudo tcpdump -i wlan0
ENTER
DELAY 1000
CTRL ALT t
DELAY 4000
STRING ssh -i ~/.ssh/pizero_key transient@192.168.1.132
ENTER
DELAY 3000
STRING realshookones
ENTER
DELAY 5000
STRING tshark -i wlan0
ENTER
